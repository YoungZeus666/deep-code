# AI Deep Coder Configuration
# Copy this file to .env and fill in your API keys.
#
# The system auto-detects the provider based on which MODEL var is set.
# Priority: OPENAI_LIKE_MODEL > OPENAI_MODEL > ANTHROPIC_MODEL (default)

# ── Provider 1: Anthropic (default) ──
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Provider 2: OpenAI ──
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o

# ── Provider 3: OpenAI-Like (any OpenAI-compatible endpoint) ──
# Works with: Qwen, MiniMax, Kimi, DeepSeek, GLM, Doubao, Ollama, vLLM, etc.
# OPENAI_LIKE_MODEL=qwen-max
# OPENAI_LIKE_API_KEY=your-api-key
# OPENAI_LIKE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Workspace ──
# AI_DEEP_CODER_WORKSPACE=/path/to/your/project
